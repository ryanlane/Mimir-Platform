# Mimir API Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_URL=sqlite:///./app.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=60
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
DEBUG=false

# Security Configuration
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://oak:3000,http://127.0.0.1:3000,http://oak,http://localhost,http://127.0.0.1
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Channels Configuration
CHANNELS_DIRECTORY=channels
MAX_CHANNEL_INSTANCES=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=20
WEBSOCKET_PING_TIMEOUT=10

# Redis Configuration (optional)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Distribution Configuration
DISTRIBUTION_ENABLED=false
DISTRIBUTION_DEFAULT_MODE=MIRROR

# Feature Flags
ENABLE_METRICS=false
ENABLE_TRACING=false
