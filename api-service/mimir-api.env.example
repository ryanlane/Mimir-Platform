# /etc/mimir/mimir-api.env
# Database
DB_URL=sqlite:////var/lib/mimir-api/mimir.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# API
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
DEBUG=false

# Paths (ABSOLUTE; not "channels" or "./app.db")
DB_URL=sqlite:////var/lib/mimir-api/mimir.db
UPLOAD_DIR=/var/opt/mimir/mimir-api/uploads
CHANNELS_DIR=/var/opt/mimir/mimir-api/channels

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis (disabled unless you turn it on)
REDIS_ENABLED=false