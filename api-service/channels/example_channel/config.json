{
  "schemaVersion": "2.1",
  "id": "example_channel",
  "name": "Example Channel",
  "description": "Sample photo display channel for testing",
  "version": "1.0.0",
  "update_schedule": {
    "unit": "hours",
    "duration": 1
  },
  "permissions": ["read:photos"],
  "settings_type": "simple",
  "settings": {
    "image_choice": {
      "type": "string",
      "enum": ["image1", "image2"],
      "label": "Image to Display",
      "default": "image1"
    },
    "update_interval_unit": {
      "type": "string",
      "enum": ["days", "hours", "minutes", "seconds"],
      "label": "Update Interval Unit",
      "default": "minutes"
    },
    "update_interval_value": {
      "type": "integer",
      "minimum": 1,
      "label": "Update Interval Value",
      "default": 5
    }
  }
}
