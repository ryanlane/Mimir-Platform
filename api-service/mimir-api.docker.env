# Docker-friendly defaults for local compose usage
# Safe to commit (no secrets). Override via environment or your own env file.

# API
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=plain

# Database (Postgres)
# NOTE: If you need to keep SQLite temporarily, set DB_URL=sqlite:////var/lib/mimir-api/mimir.db
DB_URL=postgresql+psycopg2://mimir:mimir@db:5432/mimir

# Paths (persisted via docker volumes / bind mounts)
UPLOAD_DIR=/var/opt/mimir/mimir-api/uploads
CHANNELS_DIR=/var/opt/mimir/mimir-api/channels

# CORS (comma-separated supported)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000

# Redis (enabled by default for distribution)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379

# MQTT (enabled by default in docker; uses bundled broker)
MQTT_ENABLED=true
MQTT_HOST=mqtt
MQTT_PORT=1883
MDNS_DISCOVERY_ENABLED=false
MDNS_EXTERNAL_FEED_ENABLED=true

# Optional: set this to require a token header from the discovery sidecar.
# MDNS_EXTERNAL_FEED_TOKEN=change-me
