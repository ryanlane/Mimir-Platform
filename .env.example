# ── Mimir Service — root environment ─────────────────────────────────────────
# Copy this file to .env and fill in values for your deployment.
# Used by Taskfile.yml for the health:prod and display:* tasks.
# For WSL/browser-local use, these can stay blank.

# LAN IP or hostname of the machine running docker compose.
# Set this so physical display devices can reach the API and MQTT broker.
# Example: PUBLIC_HOST=192.168.1.50
PUBLIC_HOST=

# mDNS hostname for the server advertisement (used by discovery sidecar).
# Defaults to mimir.local if not set.
# Example: PUBLIC_MDNS_HOST=mimir.local
PUBLIC_MDNS_HOST=

# If the MQTT broker is on a different host than the API, override it here.
# Leave blank to use PUBLIC_HOST.
MQTT_PUBLIC_HOST=
MQTT_PUBLIC_PORT=
