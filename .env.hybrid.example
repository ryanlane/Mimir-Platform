# Hybrid Linux deployment example for a native Ubuntu server.
# Copy this to .env in the service root, then adjust the values for your LAN.

# Externally reachable API/UI identity.
PUBLIC_HOST=192.168.1.50
REACT_APP_API_URL=http://192.168.1.50:5000

# Optional if you advertise a stable .local name from the Ubuntu host.
# PUBLIC_MDNS_HOST=mimir.local

# MQTT host exposed to physical displays. Set this to the server's LAN IP or hostname.
MQTT_PUBLIC_HOST=192.168.1.50
# REQUIRED: must stay 1883 (the authenticated LAN listener). If unset, the API
# falls back to its own broker port (1884, localhost-only) and displays will
# be handed an unreachable port.
MQTT_PUBLIC_PORT=1883

# --- MQTT auth (LAN listener) ---
# Generated/wired by scripts/phase0_harden.sh. The broker requires these on
# port 1883; displays receive them automatically during bootstrap because
# MQTT_EXPOSE_CREDENTIALS=true.
MQTT_USER=mimir-display
MQTT_PASSWORD=change-me
MQTT_EXPOSE_CREDENTIALS=true

# --- Postgres ---
# Only applied to a fresh volume; phase0_harden.sh rotates an existing DB.
POSTGRES_PASSWORD=change-me

# --- pgAdmin (optional 'tools' profile; bound to 127.0.0.1) ---
# PGADMIN_EMAIL=admin@mimirframe.com
# PGADMIN_PASSWORD=change-me

# Optional shared secret between the API and the host-native discovery service.
# If set here, also export the same value in the discovery service environment.
# MIMIR_DISCOVERY_TOKEN=change-me