{
  "id": "photo_frame",
  "name": "Photo Frame Channel",
  "version": "1.0.0",
  "description": "Displays photos from gallery in a photo frame style with randomization",
  "type": "embedded",
  "entry_point": "channel.py",
  "class_name": "PhotoFrameChannel",
  "icon": "photo",
  "config": {
    "supports_upload": true,
    "supports_gallery": true,
    "image_formats": ["jpg", "jpeg", "png", "gif"],
    "max_file_size": "10MB"
  },
  "endpoints": [
    {
      "path": "/manifest",
      "method": "GET",
      "description": "Get channel manifest and capabilities"
    },
    {
      "path": "/request_image",
      "method": "POST", 
      "description": "Request a random image from the gallery"
    },
    {
      "path": "/upload",
      "method": "POST",
      "description": "Upload new images to the gallery"
    },
    {
      "path": "/gallery",
      "method": "GET",
      "description": "List all images in the gallery"
    }
  ]
}
