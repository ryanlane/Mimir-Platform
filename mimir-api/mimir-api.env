  GNU nano 8.1                                                 /etc/mimir/mimir-api.env                                                          # Database
DB_URL=sqlite:////var/lib/mimir-api/mimir.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# API
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
DEBUG=false

# Paths (ABSOLUTE; not "channels" or "./app.db")
DB_URL=sqlite:////var/lib/mimir-api/mimir.db
UPLOAD_DIR=/var/opt/mimir/mimir-api/uploads
CHANNELS_DIR=/var/opt/mimir/mimir-api/channels

#CORS
CORS_ORIGINS=["http://mimir-server","http://mimir-server:80","http://localhost","http://127.0.0.1"]

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Redis (disabled unless you turn it on)
REDIS_ENABLED=true

DEBUG=true
