# Docker-friendly defaults for local compose usage
# Safe to commit (no secrets). Override via environment or your own env file.

# API
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=plain

# Database (Postgres)
# NOTE: If you need to keep SQLite temporarily, set DB_URL=sqlite:////var/lib/mimir-api/mimir.db
DB_URL=postgresql+psycopg2://mimir:mimir@db:5432/mimir

# Paths (persisted via docker volumes / bind mounts)
UPLOAD_DIR=/var/opt/mimir/mimir-api/uploads
CHANNELS_DIR=/var/opt/mimir/mimir-api/channels

# CORS (comma-separated or JSON array)
# Covers standard local dev ports. To add LAN/remote origins without replacing this
# list, set CORS_ORIGINS_EXTRA in your environment or a local override env file:
#   CORS_ORIGINS_EXTRA=http://192.168.1.50:8080,https://mimir.yourdomain.com
CORS_ORIGINS=http://mimir.local:8080,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS_EXTRA=

# Redis (enabled by default for distribution)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379

# MQTT (enabled by default in docker; uses bundled broker)
MQTT_ENABLED=true
MQTT_HOST=mqtt
MQTT_PORT=1883
MDNS_DISCOVERY_ENABLED=false
MDNS_EXTERNAL_FEED_ENABLED=true

# Optional: set this to require a token header from the discovery sidecar.
# MDNS_EXTERNAL_FEED_TOKEN=change-me

# --- Display client self-configuration (pushed during pairing) ---
# Set PUBLIC_HOST to the LAN IP or hostname of this machine so display
# clients can find the API and MQTT broker after being paired.
# Without this, clients on a different network segment will fall back to
# the hostname of the API container, which is usually not reachable from
# physical hardware.
#
#   PUBLIC_HOST=192.168.1.50          # LAN IP of the machine running compose
#   PUBLIC_MDNS_HOST=mimir.local      # friendly local hostname if advertised via mDNS
#   MQTT_PUBLIC_HOST=192.168.1.50     # if MQTT broker is on a different host
#
# MQTT_EXPOSE_CREDENTIALS=false  # set true to push username/password to clients
